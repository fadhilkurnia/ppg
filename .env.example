# Required: HMAC secret for signing JWTs (>= 32 bytes).
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-secret-of-at-least-32-bytes

# Optional: token lifetime (Go duration). Default: 24h.
JWT_TTL=24h

# Set true behind HTTPS in production (cookie sent only on TLS).
COOKIE_SECURE=false

# Where SQLite stores its file. Default: ./data/app.db
# In Docker the compose file pins this to /app/data/app.db.
DATABASE_PATH=./data/app.db

# Optional bootstrap admin (seeded only if users table is empty).
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme

# HTTP listen port (default 8080).
PORT=8080

# Set 1 to skip serving the embedded SPA (Vite dev server takes over on :5173).
DEV=0

# Admin WhatsApp number for the /absen report (e.g. 6281234567890). The
# /absen handler bakes this into a wa.me click-to-chat link the SPA opens
# after submit; leave empty to hide the "Kirim ke WhatsApp" button.
WHATSAPP_ADMIN_NUMBER=

# Optional CSRF defence-in-depth. When true, /api/* is also reachable at a
# per-session 12-hex prefix (e.g. /a3f8d2e1b9c7/auth/me). The prefix is
# issued at login as the `auth_path` cookie and injected into index.html.
# See docs/missing-features/50-security-hardening.md §3.
DYNAMIC_API_PATH=false

# Cloudflare Tunnel token. Create the tunnel in the Cloudflare Zero Trust
# dashboard (Networks -> Tunnels -> Create), then point its public hostname
# at http://app:8080. Paste the issued token here and start with:
#   docker compose --profile tunnel up -d
# Leave empty to skip the cloudflared sidecar.
CLOUDFLARE_TUNNEL_TOKEN=
